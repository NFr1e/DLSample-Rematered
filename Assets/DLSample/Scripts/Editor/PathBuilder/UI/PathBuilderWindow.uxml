            <ui:VisualElement name="Content" style="flex-grow: 1; background-color: rgb(50, 50, 50); border-top-left-radius: 2px; border-top-right-radius: 2px; border-bottom-right-radius: 2px; border-bottom-left-radius: 2px; padding-top: 2px; padding-right: 2px; padding-bottom: 2px; padding-left: 2px;">
                <uie:ObjectField label="HintBoxPrefab" name="HintBoxPrefabField" type="UnityEngine.GameObject, UnityEngine.CoreModule" />
                <uie:ObjectField label="HintSegmentPrefab" name="HintSegmentPrefabField" type="UnityEngine.GameObject, UnityEngine.CoreModule" />
                <ui:VisualElement name="Buttons" style="flex-grow: 1; flex-direction: row-reverse;">
                    <ui:Button text="Generate" parse-escape-sequences="true" display-tooltip-when-elided="true" name="GeneratePathButton" style="margin-top: 2px; margin-right: 2px; margin-bottom: 2px; margin-left: 2px; flex-grow: 1;" />
                    <ui:Button text="GenerateBoxOnly" parse-escape-sequences="true" display-tooltip-when-elided="true" name="GeneratePathButton" style="margin-top: 2px; margin-right: 2px; margin-bottom: 2px; margin-left: 2px; flex-grow: 0;" />
